# Git
.git/
.gitignore
.gitattributes

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Python（遞迴排除所有子目錄）
**/__pycache__/
*.py[cod]
*$py.class
**/*.egg-info/
**/dist/
**/build/
**/.pytest_cache/
**/.mypy_cache/
.venv/
venv/
env/
ENV/

# Node（遞迴排除，包含 python-analytics/.../node_modules）
**/node_modules/
npm-debug.log*
yarn-error.log*
.next/

# Rust（遞迴排除，包含 rust-engine/target）
**/target/
# Cargo.lock 保留以確保可重現 build
*.rlib
*.rmeta
*.so
*.dylib

# 文檔 & 草稿（不需進容器）
docs/
*.md

# 敏感檔案（即使 .gitignore 已列出）
.env
.env.local
.env.*.local
*.pem
*.key

# 測試與覆蓋
coverage/
.coverage

# 數據（本機 dry_run）
data/
*.db
*.sqlite
*.sqlite3

# Docker 相關
docker-compose.override.yml
